const express = require('express');
const cors = require('cors');
const path = require('path');
const fs = require('fs');

const app = express();
const PORT = process.env.PORT || 3000;

app.use(cors());
app.use(express.json());
app.use(express.static('.'));

// Agent configuration
const agents = [
    { name: 'Nexus', port: 18789, channel: 'main', type: 'primary', role: 'COO / Main Orchestrator' },
    { name: 'Dearnote', port: 18800, channel: '#dearnote', type: 'service', role: 'AI Gratitude Messaging App' },
    { name: 'Noyoupick', port: 18810, channel: '#noyoupick', type: 'service', role: 'Decision-Making Assistant' },
    { name: 'Ghostreel', port: 18820, channel: '#ghostreel', type: 'service', role: 'YouTube/TikTok Content Automation' },
    { name: 'Quickdraw', port: 18830, channel: '#quickdraw', type: 'service', role: 'Solana DEX Trading Bot' }
];

// ---- Existing endpoints ----
app.get('/api/agents', (req, res) => res.json(agents));

app.get('/api/health', (req, res) => {
    res.json({ status: 'healthy', timestamp: new Date().toISOString(), uptime: process.uptime(), version: '2.0.0' });
});

app.get('/api/agent/:name/health', async (req, res) => {
    const agent = agents.find(a => a.name.toLowerCase() === req.params.name.toLowerCase());
    if (!agent) return res.status(404).json({ error: 'Agent not found' });
    try {
        const fetch = require('node-fetch');
        const response = await fetch(`http://localhost:${agent.port}/health`, { timeout: 5000 });
        const data = await response.text();
        res.json({ status: 'running', port: agent.port, response: data, timestamp: new Date().toISOString() });
    } catch (error) {
        res.json({ status: 'stopped', port: agent.port, error: error.message, timestamp: new Date().toISOString() });
    }
});

// ---- Tasks API ----
function parseTodoMd(filePath, source) {
    try {
        const content = fs.readFileSync(filePath, 'utf-8');
        const tasks = [];
        const lines = content.split('\n');
        let section = '';
        for (const line of lines) {
            if (line.startsWith('## ')) section = line.replace('## ', '').trim();
            const m = line.match(/^[-*]\s+\[([ x])\]\s+(.+)/);
            if (m) {
                const done = m[1] === 'x';
                let title = m[2].replace(/~~(.+?)~~/g, '$1').replace(/\*\*(.+?)\*\*/g, '$1').trim();
                const assignee = section.toLowerCase().includes('shawn') || source === 'personal' ? 'Shawn' : 'Nexus';
                tasks.push({ title, done, section, source, assignee });
            }
        }
        return tasks;
    } catch { return []; }
}

app.get('/api/tasks', (req, res) => {
    const personal = parseTodoMd('/root/.openclaw/workspace/todo-personal.md', 'personal');
    const work = parseTodoMd('/root/.openclaw/workspace/todo-work.md', 'work');
    res.json([...personal, ...work]);
});

// ---- Pipeline API ----
app.get('/api/pipeline', (req, res) => {
    const outputDir = '/root/.openclaw/workspace/work/ghostreel/output/';
    try {
        const entries = fs.readdirSync(outputDir, { withFileTypes: true });
        const items = entries.filter(e => e.isDirectory()).map(dir => {
            const dirPath = path.join(outputDir, dir.name);
            const files = fs.readdirSync(dirPath);
            const hasScript = files.some(f => f.includes('script') || f.endsWith('.txt') || f.endsWith('.md'));
            const hasAudio = files.some(f => f.includes('voiceover') || f.endsWith('.mp3') || f.endsWith('.wav'));
            const hasVideo = files.some(f => f.endsWith('.mp4'));
            const hasThumbnail = files.some(f => f.includes('thumbnail'));
            let stage = 'Idea';
            if (hasScript) stage = 'Script';
            if (hasAudio) stage = 'Voiceover';
            if (hasVideo) stage = 'Assembly';
            if (hasVideo && hasThumbnail) stage = 'Upload';
            const stat = fs.statSync(dirPath);
            return { name: dir.name, files, stage, timestamp: stat.mtime.toISOString() };
        });
        res.json(items);
    } catch { res.json([]); }
});

// ---- Calendar API ----
app.get('/api/calendar', (req, res) => {
    const cronDirs = [
        '/root/.openclaw/cron/jobs.json',
        '/root/.openclaw/agents/main/state/cron/jobs.json',
        '/root/.openclaw/agents/dearnote/state/cron/jobs.json',
        '/root/.openclaw/agents/ghostreel/state/cron/jobs.json',
        '/root/.openclaw/agents/noyoupick/state/cron/jobs.json',
        '/root/.openclaw/agents/quickdraw/state/cron/jobs.json',
    ];
    const allJobs = [];
    for (const p of cronDirs) {
        try {
            const data = JSON.parse(fs.readFileSync(p, 'utf-8'));
            const agent = p.includes('/agents/') ? p.split('/agents/')[1].split('/')[0] : 'main';
            const jobs = Array.isArray(data) ? data : (data.jobs || []);
            jobs.forEach(j => allJobs.push({ ...j, agent: j.agent || agent }));
        } catch {}
    }
    res.json(allJobs);
});

// ---- Memory API ----
const MEMORY_DIR = '/root/.openclaw/workspace/memory';
const MEMORY_FILE = '/root/.openclaw/workspace/MEMORY.md';

app.get('/api/memories', (req, res) => {
    const files = [];
    try {
        const stat = fs.statSync(MEMORY_FILE);
        files.push({ filename: 'MEMORY.md', size: stat.size, modified: stat.mtime.toISOString(), path: 'MEMORY.md' });
    } catch {}
    try {
        for (const f of fs.readdirSync(MEMORY_DIR)) {
            if (!f.endsWith('.md')) continue;
            const fp = path.join(MEMORY_DIR, f);
            const stat = fs.statSync(fp);
            files.push({ filename: f, size: stat.size, modified: stat.mtime.toISOString(), path: 'memory/' + f });
        }
    } catch {}
    files.sort((a, b) => b.modified.localeCompare(a.modified));
    res.json(files);
});

app.get('/api/memory/search', (req, res) => {
    const q = (req.query.q || '').toLowerCase();
    if (!q) return res.json([]);
    const results = [];
    const searchFile = (fp, name) => {
        try {
            const content = fs.readFileSync(fp, 'utf-8');
            if (content.toLowerCase().includes(q)) {
                const lines = content.split('\n');
                const matches = lines.filter(l => l.toLowerCase().includes(q)).slice(0, 3);
                results.push({ filename: name, matches });
            }
        } catch {}
    };
    searchFile(MEMORY_FILE, 'MEMORY.md');
    try {
        for (const f of fs.readdirSync(MEMORY_DIR)) {
            if (f.endsWith('.md')) searchFile(path.join(MEMORY_DIR, f), f);
        }
    } catch {}
    res.json(results);
});

app.get('/api/memory/:filename', (req, res) => {
    const fn = req.params.filename;
    let fp;
    if (fn === 'MEMORY.md') fp = MEMORY_FILE;
    else fp = path.join(MEMORY_DIR, fn);
    try {
        if (!fp.startsWith(MEMORY_DIR) && fp !== MEMORY_FILE) return res.status(403).json({ error: 'Forbidden' });
        const content = fs.readFileSync(fp, 'utf-8');
        res.type('text/plain').send(content);
    } catch { res.status(404).json({ error: 'Not found' }); }
});

// Serve pages
app.get('/', (req, res) => res.sendFile(path.join(__dirname, 'index.html')));

app.listen(PORT, () => {
    console.log(`🚀 Alfred Dashboard v2.0 running on http://localhost:${PORT}`);
    console.log(`📊 Monitoring ${agents.length} agents`);
});

module.exports = app;
